# CreatorOS - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ═════════════════════════════════════════════════════════════════
#  APPLICATION SETTINGS
# ═════════════════════════════════════════════════════════════════

FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-too
OAUTH_STATE_SECRET=your-oauth-state-signing-secret
ADMIN_SECRET_CODE=your-admin-secret-code
AUTH_ACCESS_TOKEN_DAYS=30
OAUTH_STATE_MAX_AGE_SECONDS=600
API_REQUEST_TIMEOUT_SECONDS=15
MAX_CONTENT_LENGTH=26214400
JWT_TOKEN_LOCATION=headers,cookies
JWT_ACCESS_COOKIE_NAME=access_token_cookie
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=true
AUTH_EXPOSE_ACCESS_TOKEN=false

# Rate limiting
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_AUTH=10 per minute
RATELIMIT_AI=30 per hour
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_HEADERS_ENABLED=true

# Database URL (SQLite for dev, PostgreSQL for production)
DATABASE_URL=postgresql://user:password@localhost:5432/creatorOS
# DATABASE_URL=sqlite:///creatorOS.db  # Development
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_AUTO_CREATE=false

# ═════════════════════════════════════════════════════════════════
#  GOOGLE OAUTH (YouTube & Gmail)
# ═════════════════════════════════════════════════════════════════
# Get from: https://console.cloud.google.com

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback
GOOGLE_PLATFORM_CALLBACK_URL=https://yourdomain.com/api/platforms/youtube/callback
# For development:
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_PLATFORM_CALLBACK_URL=http://localhost:5000/api/platforms/youtube/callback
# GOOGLE_PLATFORM_CALLBACK_URL=http://localhost:5000/api/platforms/youtube/callback

# ═════════════════════════════════════════════════════════════════
#  INSTAGRAM OAUTH (Meta Business)
# ═════════════════════════════════════════════════════════════════
# Get from: https://developers.facebook.com

INSTAGRAM_CLIENT_ID=YOUR_INSTAGRAM_APP_ID_HERE
INSTAGRAM_CLIENT_SECRET=YOUR_INSTAGRAM_APP_SECRET_HERE
INSTAGRAM_CALLBACK_URL=https://yourdomain.com/api/platforms/instagram/callback
INSTAGRAM_TEST_MODE=false
# For development:
# INSTAGRAM_CALLBACK_URL=http://localhost:5000/api/platforms/instagram/callback
# INSTAGRAM_TEST_MODE=true

# ═════════════════════════════════════════════════════════════════
#  TIKTOK OAUTH
# ═════════════════════════════════════════════════════════════════
# Get from: https://developer.tiktok.com

TIKTOK_CLIENT_ID=YOUR_TIKTOK_CLIENT_ID_HERE
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET_HERE
TIKTOK_CALLBACK_URL=https://yourdomain.com/api/platforms/tiktok/callback
# For development:
# TIKTOK_CALLBACK_URL=http://localhost:5000/api/platforms/tiktok/callback

# ═════════════════════════════════════════════════════════════════
#  TWITTER/X OAUTH
# ═════════════════════════════════════════════════════════════════
# Get from: https://developer.twitter.com

TWITTER_API_KEY=YOUR_TWITTER_API_KEY_HERE
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET_HERE
TWITTER_CLIENT_ID=YOUR_TWITTER_CLIENT_ID_HERE
TWITTER_CLIENT_SECRET=YOUR_TWITTER_CLIENT_SECRET_HERE
TWITTER_SCOPES=tweet.read users.read offline.access
TWITTER_CALLBACK_URL=https://yourdomain.com/api/platforms/twitter/callback
# For development:
# TWITTER_CALLBACK_URL=http://localhost:5000/api/platforms/twitter/callback

# ═════════════════════════════════════════════════════════════════
#  LINKEDIN OAUTH
# ═════════════════════════════════════════════════════════════════
# Get from: https://www.linkedin.com/developers

LINKEDIN_CLIENT_ID=YOUR_LINKEDIN_CLIENT_ID_HERE
LINKEDIN_CLIENT_SECRET=YOUR_LINKEDIN_CLIENT_SECRET_HERE
LINKEDIN_CALLBACK_URL=https://yourdomain.com/api/platforms/linkedin/callback
LINKEDIN_SCOPES=openid profile email
# For development:
# LINKEDIN_CALLBACK_URL=http://localhost:5000/api/platforms/linkedin/callback

# ═════════════════════════════════════════════════════════════════
#  AI GENERATION (OpenAI-compatible)
# ═════════════════════════════════════════════════════════════════

AI_ENABLED=true
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30

# ═════════════════════════════════════════════════════════════════
#  FRONTEND URL
# ═════════════════════════════════════════════════════════════════

FRONTEND_URL=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
FRONTEND_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# For development:
# FRONTEND_URL=http://localhost:3000
# CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
# FRONTEND_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ═════════════════════════════════════════════════════════════════
#  REDIS (for caching & sessions)
# ═════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://user:password@redis-host:6379/0  # Production

# ═════════════════════════════════════════════════════════════════
#  EMAIL CONFIGURATION (optional, for notifications)
# ═════════════════════════════════════════════════════════════════

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com

# ═════════════════════════════════════════════════════════════════
#  CELERY CONFIGURATION (for background tasks)
# ═════════════════════════════════════════════════════════════════

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ═════════════════════════════════════════════════════════════════
#  SENTRY (Error Tracking - optional)
# ═════════════════════════════════════════════════════════════════

SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ═════════════════════════════════════════════════════════════════
#  LOGGING
# ═════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_FILE=${LOG_FILE:-logs/app.log}

# ═════════════════════════════════════════════════════════════════
#  ANALYTICS SYNC SCHEDULE
# ═════════════════════════════════════════════════════════════════

# Interval in seconds between analytics syncs (3600 = 1 hour)
ANALYTICS_SYNC_INTERVAL=3600
