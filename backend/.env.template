# Backend environment example (sanitized)
# Copy to backend/.env and fill in real values. Never commit real secrets.

FLASK_ENV=production
FLASK_APP=app.py
PORT=5000

# Security
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
OAUTH_STATE_SECRET=change-me
ADMIN_SECRET_CODE=change-me

AUTH_ACCESS_TOKEN_DAYS=30
OAUTH_STATE_MAX_AGE_SECONDS=600
API_REQUEST_TIMEOUT_SECONDS=15
MAX_CONTENT_LENGTH=26214400

# JWT cookies
JWT_TOKEN_LOCATION=headers,cookies
JWT_ACCESS_COOKIE_NAME=access_token_cookie
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=true
AUTH_EXPOSE_ACCESS_TOKEN=false

# Rate limiting
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_AUTH=10 per minute
RATELIMIT_AI=30 per hour
RATELIMIT_POSTS=60 per hour
RATELIMIT_UPLOAD=20 per hour
RATELIMIT_FEEDBACK=10 per hour
RATELIMIT_ADMIN=60 per minute
RATELIMIT_NOTIFICATIONS=120 per minute
RATELIMIT_SYNC=10 per hour
RATELIMIT_STORAGE_URI=redis://host:6379/0
RATELIMIT_HEADERS_ENABLED=true

# Database
DATABASE_URL=postgresql://user:password@host:5432/creatorOS
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_AUTO_CREATE=false

# Frontend / CORS
FRONTEND_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
FRONTEND_ALLOWED_ORIGINS=https://app.example.com

# Google OAuth (YouTube)
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
GOOGLE_PLATFORM_CALLBACK_URL=https://api.example.com/api/platforms/youtube/callback

# Instagram OAuth
INSTAGRAM_CLIENT_ID=change-me
INSTAGRAM_CLIENT_SECRET=change-me
INSTAGRAM_CALLBACK_URL=https://api.example.com/api/platforms/instagram/callback
INSTAGRAM_TEST_MODE=false

# TikTok OAuth (currently disabled in code paths)
TIKTOK_CLIENT_ID=change-me
TIKTOK_CLIENT_SECRET=change-me
TIKTOK_CALLBACK_URL=https://api.example.com/api/auth/tiktok/callback
TIKTOK_PLATFORM_CALLBACK_URL=https://api.example.com/api/platforms/tiktok/callback

# Twitter/X OAuth
TWITTER_API_KEY=change-me
TWITTER_API_SECRET=change-me
TWITTER_CLIENT_ID=change-me
TWITTER_CLIENT_SECRET=change-me
TWITTER_SCOPES=tweet.read users.read offline.access
TWITTER_CALLBACK_URL=https://api.example.com/api/platforms/twitter/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=change-me
LINKEDIN_CLIENT_SECRET=change-me
LINKEDIN_CALLBACK_URL=https://api.example.com/api/platforms/linkedin/callback
LINKEDIN_SCOPES=openid profile email

# AI Generation
AI_ENABLED=true
OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
GEMINI_API_KEY=change-me

# Logging / Sentry
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# Redis / Celery
REDIS_URL=redis://host:6379/0
CELERY_BROKER_URL=redis://host:6379/1
CELERY_RESULT_BACKEND=redis://host:6379/2
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_BROKER_POOL_LIMIT=10
DUE_POSTS_INTERVAL_SECONDS=60
DUE_POSTS_BATCH_SIZE=200
CLEANUP_SESSIONS_INTERVAL_MINUTES=60
ANALYTICS_SYNC_INTERVAL_MINUTES=60
ANALYTICS_SYNC_BATCH_SIZE=200

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/var/lib/creatoros/uploads
STORAGE_TEMP_DIR=/tmp
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
